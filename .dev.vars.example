# Local Wrangler values only. Copy to .dev.vars if an explicit override is
# needed; Wrangler development already receives these defaults from
# wrangler.jsonc.
RUNTIME_MODE=preview
OPENAI_MODE=disabled

# Never place OPENAI_API_KEY_JUDGE or JUDGE_IP_HMAC_SECRET here. Judge mode
# uses separate `wrangler secret put` operations at the explicitly approved
# deployment boundary.
