# Copy to .env for local development. Never commit the copied file.

NODE_ENV=development

# Bind development servers to all interfaces so they are reachable through Tailscale.
HOST=0.0.0.0
PORT=8787
WEB_PORT=5173

# Production-like Compose origin. Use this machine's Tailscale IPv4 address
# for PUBLIC_HOST when opening the app from another device.
COMPOSE_PORT=8080
PUBLIC_HOST=localhost

# Local-only OpenAI key. Leave empty for AI-disabled manual fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# Optional local signed-webhook secret. Leave empty to disable the external
# webhook route; the facilitator's labeled synthetic demo event remains local.
REGULATORY_WEBHOOK_SECRET=
REGULATORY_WEBHOOK_MAX_AGE_SECONDS=300

# Local persistence paths. These should stay under the ignored data/ directory.
DATABASE_PATH=./data/counterpoint.sqlite
STORAGE_PATH=./data/artifacts

# Optional override for the fixed synthetic users. Supply 3–8 entries with one
# facilitator and scrypt password hashes; plaintext passwords are never stored.
# DEMO_USERS_JSON=[{"userId":"product","role":"facilitator","passwordHash":"scrypt$v1$..."}]

# Set this only when the local runtime needs an explicit public origin.
APP_ORIGIN=http://localhost:8787

# Cloudflare preview deployment inputs. Keep the API token out of committed
# files; provide these values through the shell or the protected GitHub
# `preview` Environment when deploying.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_DEPLOY_URL=

# Production-only judge opt-in. Leave empty for preview and ordinary deploys.
# The deployment guard still requires CLOUDFLARE_DEPLOYMENT_APPROVED=production
# and CLOUDFLARE_PRODUCTION_CONFIRMATION=counterpoint-production.
CLOUDFLARE_ENABLE_JUDGE_MODE=
CLOUDFLARE_JUDGE_USER_ID=

# OPENAI_API_KEY_JUDGE must be configured as a Cloudflare Worker Secret only.
# It must not be placed in .env, .dev.vars, wrangler.toml, source, or logs.
# JUDGE_IP_HMAC_SECRET is a separate Cloudflare Worker Secret used only to
# pseudonymize the exact Cloudflare-verified client IP for judge rate limits.
# Never reuse the OpenAI key or place this HMAC secret in local env files.
