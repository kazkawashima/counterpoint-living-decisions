{
  "name": "counterpoint-living-decisions",
  "version": "0.0.0",
  "private": true,
  "description": "Counterpoint — Living Decisions hackathon monorepo",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "24.15.0",
    "npm": "11.12.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run bundle --workspace @counterpoint/web",
    "clean": "tsc -b --clean",
    "contract": "vitest run --project contract",
    "compose:config": "docker compose config --quiet",
    "compose:up": "docker compose up --build",
    "deploy:smoke": "npm run build && node scripts/deployment-smoke.mjs",
    "dev": "npm run dev --workspace @counterpoint/web",
    "dev:server": "npm run dev --workspace @counterpoint/server",
    "dev:web": "npm run dev --workspace @counterpoint/web",
    "e2e": "playwright test",
    "env:check": "node scripts/check-environment.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "integration": "vitest run --project integration",
    "lint": "eslint .",
    "smoke:openai": "npm run build --workspace @counterpoint/adapters-openai && node --env-file-if-exists=.env scripts/openai-private-disclosure-smoke.mjs",
    "smoke:openai:invalidation": "npm run build --workspace @counterpoint/adapters-openai && node --env-file-if-exists=.env scripts/openai-assumption-invalidation-smoke.mjs",
    "smoke:openai:decision": "npm run build --workspace @counterpoint/adapters-openai && node --env-file-if-exists=.env scripts/openai-shared-decision-smoke.mjs",
    "smoke:openai:realtime-secret": "npm run build --workspace @counterpoint/adapters-openai && node --env-file-if-exists=.env scripts/openai-realtime-secret-smoke.mjs",
    "test": "vitest run",
    "test:architecture": "node scripts/check-architecture.mjs",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "unit": "vitest run --project unit"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
